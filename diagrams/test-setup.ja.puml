@startuml
title 参考：自作 CPU 用のテスト環境構成例

skinparam shadowing false
skinparam componentStyle rectangle
hide <<plain>> stereotype

skinparam rectangle {
    BackgroundColor<<cpu>> #FFF3E0
    BorderColor<<cpu>> #E65100
    BackgroundColor<<bridge>> #FFEBEE
    BorderColor<<bridge>> #C62828
    BackgroundColor<<pc>> #E3F2FD
    BorderColor<<pc>> #1565C0
    BackgroundColor<<tool>> #F1F8E9
    BorderColor<<tool>> #558B2F
    BackgroundColor<<plain>> transparent
    BorderColor<<plain>> transparent
    Shadowing<<plain>> false
}

rectangle "自作 CPU\n(FPGA / MCU / ディスクリート / etc.)" as cpu <<cpu>>

rectangle "USB-UART 変換器\n(CP210x / CH340 / FTDI 等)" as bridge <<bridge>>

rectangle "PC (Windows / Mac / Linux)" as pc <<pc>> {
  rectangle "シリアル端末\n(VSCode Serial Monitor /\n TeraTerm / minicom)" as term <<tool>>
  rectangle "シリアル送受信\n対局プログラム" as pyser <<tool>>
}

cpu -right-> bridge : UART
bridge -right-> pc : USB

rectangle "<latex>\phantom{XXXXXXXXXXXXXXXXXX}\underbrace{\phantom{XXXXXXXXXXXXXXXXXXXXXXXXX}}_{\textcolor{red}{\textbf{\Large 本書規定の UART プロトコル}}}</latex>" as proto <<plain>>
bridge -[hidden]down- proto

note bottom of term
  手打ちで "SB", "MOd3", "PI" 等を
  送信して CPU の応答を確認
end note

note bottom of pyser
  本仕様の各行を自動送受信し、
  対局シーケンスを再現して
  CPU 実装を検証
end note

@enduml
